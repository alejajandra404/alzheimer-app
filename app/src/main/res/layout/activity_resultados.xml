<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTituloResultados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resultados y Progreso"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E293B" />

        <TextView
            android:id="@+id/tvPacienteResultados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Paciente: Juan Pérez"
            android:textSize="16sp"
            android:textColor="#475569" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Último puntaje MMSE"
                android:textColor="#475569"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvUltimoMmse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="24/30"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#0891B2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Último puntaje Tinetti"
                android:textColor="#475569"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvUltimoTinetti"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="18/28"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#0891B2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cambio respecto a evaluación anterior"
                android:textColor="#475569"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvCambio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="-2 puntos en MMSE"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#DC2626" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado general"
                android:textColor="#475569"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvEstadoGeneral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Estable con ligero deterioro cognitivo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0F172A" />
        </LinearLayout>

        <Button
            android:id="@+id/btnVolverHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Volver al historial" />

    </LinearLayout>
</ScrollView>